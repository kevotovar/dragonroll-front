# Required
GQL_HOST="https://wp.example.com/graphql"   # must end with /graphql
NUXT_IMAGE_DOMAINS="wp.example.com,cdn.example.com"  # hostnames only, comma-separated (no https://)

# Optional (used as the Origin header when calling WordPress)
APP_HOST="http://localhost:3000"

# ISR cache lifetime for catalog routes in seconds (product, products, product-category)
CATALOG_ISR_TTL="3600"

# If you don't have the plugin installed, you can configure the rest of the settings here.
# number of products to be displayed per page
NUXT_PUBLIC_PRODUCTS_PER_PAGE="24"

# Stripe API key
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_abcdefghijklmnopqrstuvwxyz"

# Color of input and button elements
PRIMARY_COLOR="#ff0000"

# =============================================================================
# DOCKER DEPLOYMENT CONFIGURATION
# =============================================================================
# 
# To deploy this application using Docker:
#
# 1. Build the Docker image:
#    docker build \
#      --build-arg GQL_HOST="$GQL_HOST" \
#      --build-arg NUXT_IMAGE_DOMAINS="$NUXT_IMAGE_DOMAINS" \
#      --build-arg APP_HOST="$APP_HOST" \
#      --build-arg CATALOG_ISR_TTL="$CATALOG_ISR_TTL" \
#      --build-arg NUXT_PUBLIC_PRODUCTS_PER_PAGE="$NUXT_PUBLIC_PRODUCTS_PER_PAGE" \
#      --build-arg NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="$NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY" \
#      --build-arg PRIMARY_COLOR="$PRIMARY_COLOR" \
#      -t dragonroll-front:latest .
#
# 2. Run the container:
#    docker run -d \
#      -p 3000:3000 \
#      --name dragonroll-front \
#      --restart unless-stopped \
#      dragonroll-front:latest
#
# 3. Or use Docker Compose (recommended):
#    docker-compose up -d
#
# Environment variables are injected at BUILD time, not runtime.
# This is required because Nuxt.js embeds environment variables during build.
#
# Required build arguments:
#   - GQL_HOST: Your WordPress GraphQL endpoint
#   - NUXT_IMAGE_DOMAINS: Comma-separated list of image domains
#
# Optional build arguments:
#   - APP_HOST, CATALOG_ISR_TTL, NUXT_PUBLIC_PRODUCTS_PER_PAGE
#   - NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY, PRIMARY_COLOR
#
# The production image exposes port 3000 and runs as non-root user (UID 1001).
# Health checks are performed on the /api/health endpoint.
#
# For more information, see the project documentation.

